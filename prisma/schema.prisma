generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  state       String
  type        String
  fees        Float
  rating      Float    @default(0)
  image       String?
  description String?
  website     String?
  established Int?
  reviews     Review[]
  courses     Course[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id        Int     @id @default(autoincrement())
  name      String
  duration  String
  fees      Float
  college   College @relation(fields: [collegeId], references: [id])
  collegeId Int
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Float
  comment   String
  author    String
  college   College  @relation(fields: [collegeId], references: [id])
  collegeId Int
  createdAt DateTime @default(now())
}